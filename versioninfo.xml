<?xml version="1.0" encoding="utf-8"?>
<!--
	Place this file in the root of the JVNL/PlgKunena_jnlSolved GitHub repo
	(on the branch/tag referenced by the <server> URL in jnlsolved.xml) so
	Joomla's "Check for updates" can find new releases.

	<downloadurl> below points at GitHub's auto-generated tag archive
	(archive/refs/tags/<tag>.zip) rather than a manually uploaded Release
	asset: no extra upload step needed, just push a tag. Downside: it
	bundles the whole repo (README.md, LICENSE.txt, .gitignore, this file)
	inside a `PlgKunena_jnlSolved-<tag>/` subfolder rather than the plugin
	files at the zip root. Joomla's installer normally strips a single
	top-level folder automatically, but verify a fresh install still works
	after switching this. If it ever doesn't, switch to a proper GitHub
	Release with a hand-built jnlsolved.zip (containing only the plugin
	files, no repo-root subfolder) as the release asset instead.

	On every release: bump <version> here, push a matching git tag, and
	update <downloadurl> to that tag. Update <targetplatform> too if the
	minimum Joomla version changes.
-->
<updates>
	<update>
		<name>PLG_KUNENA_JNLSOLVED</name>
		<description>PLG_KUNENA_JNLSOLVED_DESCRIPTION</description>
		<element>jnlsolved</element>
		<type>plugin</type>
		<folder>kunena</folder>
		<client>site</client>
		<version>2.0.1</version>
		<infourl title="Joomla!NL - Opgelost plugin">https://github.com/JVNL/PlgKunena_jnlSolved</infourl>
		<downloads>
			<downloadurl type="full" format="zip">https://github.com/JVNL/PlgKunena_jnlSolved/archive/refs/tags/2.0.1.zip</downloadurl>
		</downloads>
		<tags>
			<tag>stable</tag>
		</tags>
		<maintainer>Team Joomla!NL</maintainer>
		<maintainerurl>https://www.joomlanl.nl</maintainerurl>
		<targetplatform name="joomla" version="5.[0-9]+" />
	</update>
</updates>
